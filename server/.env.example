# Application
APP_NAME="Next.js Laravel Template API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Database
# Choose a Laravel-supported database when your project is ready.
# Examples:
# DB_CONNECTION=mysql
# DB_CONNECTION=pgsql
# DB_CONNECTION=sqlite
DB_CONNECTION=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessions and cookies
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Laravel Sanctum
# Include frontend domains that should be treated as first-party SPA clients.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# CORS
# Keep this aligned with the local or production frontend URL.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cache, queue, and mail defaults
CACHE_STORE=file
QUEUE_CONNECTION=sync
MAIL_MAILER=log
